# Generated by scalardb-starter-skills/scalardb-generate-springboot-starter
spring.application.name={{APP_NAME}}

# ScalarDB client properties — single source of truth under scalardb/config/
# (paths are relative to the project root; run the app with `./gradlew bootRun`)
scalardb.config.file=scalardb/config/scalardb.properties
scalardb_sql.config.file=scalardb/config/scalardb_sql.properties

# Common retry parameters (Core API and SQL API retry templates)
retry.max-attempts=3
retry.initial-delay-ms=100
retry.max-delay-ms=5000
retry.multiplier=2.0

# Swagger UI: http://localhost:8080/swagger-ui/index.html
springdoc.swagger-ui.path=/swagger-ui.html
