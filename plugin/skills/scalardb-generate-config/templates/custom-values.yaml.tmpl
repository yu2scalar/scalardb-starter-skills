# Generated by scalardb-starter-skills/scalardb-generate-config
# Helm chart : scalar-labs/scalardb-cluster {{CHART_VERSION}} (ScalarDB Cluster {{SCALARDB_VERSION}})
# Install    : see ../../README.md or run /scalardb-start-scalardb-cluster
#
# Fixed by this starter (edit here if you outgrow them):
#   - Client mode: indirect (envoy.enabled=true)
#   - TLS: off / GraphQL: off / encryption: off
#   - SQL interface: on
#   - Coordinator namespace "coordinator" on storage "{{FIRST_STORAGE}}"

envoy:
  enabled: true
  # Subchart default is 3 (production HA); 1 is plenty for this starter.
  replicaCount: {{ENVOY_REPLICA_COUNT}}
  service:
    # {{ENVOY_SERVICE_TYPE_COMMENT}}
    type: {{ENVOY_SERVICE_TYPE}}

scalardbCluster:
  replicaCount: {{REPLICA_COUNT}}
  logLevel: {{LOG_LEVEL}}

  image:
    # Pin the node image to the reference version of this starter.
    tag: "{{SCALARDB_VERSION}}"

  # Sensitive values are injected from this Secret as environment variables
  # (created by scalardb/secrets/create-scalardb-secrets.sh).
  secretName: "scalardb-credentials"
{{#if RESOURCES}}

  resources:
    requests:
      cpu: {{RESOURCES_REQUEST_CPU}}
      memory: {{RESOURCES_REQUEST_MEMORY}}
    limits:
      cpu: {{RESOURCES_LIMIT_CPU}}
      memory: {{RESOURCES_LIMIT_MEMORY}}
{{/if}}

  scalardbClusterNodeProperties: |
    # --- Cluster membership (endpoint env vars are set by the Helm chart) ---
    scalar.db.cluster.membership.type=KUBERNETES
    scalar.db.cluster.membership.kubernetes.endpoint.namespace_name=${env:SCALAR_DB_CLUSTER_MEMBERSHIP_KUBERNETES_ENDPOINT_NAMESPACE_NAME}
    scalar.db.cluster.membership.kubernetes.endpoint.name=${env:SCALAR_DB_CLUSTER_MEMBERSHIP_KUBERNETES_ENDPOINT_NAME}

    # --- Licensing (values come from the scalardb-credentials Secret) ---
    scalar.db.cluster.node.licensing.license_key=${env:CLUSTER_LICENSE_KEY}
    scalar.db.cluster.node.licensing.license_check_cert_pem=${env:LICENSE_CHECK_CERT_PEM}

    # --- Storages (multi-storage, even with a single backend) ---
    scalar.db.storage=multi-storage
    scalar.db.multi_storage.storages={{STORAGE_NAMES_CSV}}
{{#each STORAGES}}

    # storage "{{name}}" ({{backend_display}})
    scalar.db.multi_storage.storages.{{name}}.storage={{scalar_db_storage}}
    scalar.db.multi_storage.storages.{{name}}.contact_points={{contact_points}}
{{#if contact_port}}
    scalar.db.multi_storage.storages.{{name}}.contact_port={{contact_port}}
{{/if}}
{{#if emit_username}}
    scalar.db.multi_storage.storages.{{name}}.username=${env:STORAGES_{{NAME_UPPER}}_USERNAME}
{{/if}}
    scalar.db.multi_storage.storages.{{name}}.password=${env:STORAGES_{{NAME_UPPER}}_PASSWORD}
{{#if dynamo_endpoint_override}}
    scalar.db.multi_storage.storages.{{name}}.dynamo.endpoint_override={{dynamo_endpoint_override}}
{{/if}}
{{#if dynamo_namespace_prefix}}
    scalar.db.multi_storage.storages.{{name}}.dynamo.namespace.prefix={{dynamo_namespace_prefix}}
{{/if}}
{{#if cps_enabled}}
    scalar.db.multi_storage.storages.{{name}}.cross_partition_scan.enabled=true
    scalar.db.multi_storage.storages.{{name}}.cross_partition_scan.filtering.enabled={{cps_filtering}}
{{#if backend_is_jdbc}}
    scalar.db.multi_storage.storages.{{name}}.cross_partition_scan.ordering.enabled={{cps_ordering}}
{{/if}}
{{/if}}
{{/each}}

    # Namespace mapping — separator is ':' (never '='). Always written,
    # including the coordinator entry, even with a single storage.
    scalar.db.multi_storage.namespace_mapping={{NAMESPACE_MAPPING_CSV}}
    scalar.db.multi_storage.default_storage={{FIRST_STORAGE}}
    scalar.db.consensus_commit.coordinator.namespace=coordinator

    # --- Interfaces ---
    scalar.db.sql.enabled=true
    scalar.db.graphql.enabled=false

    # --- Authentication ---
    scalar.db.cluster.auth.enabled={{AUTH_ENABLED}}
