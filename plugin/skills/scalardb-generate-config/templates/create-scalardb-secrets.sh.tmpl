#!/usr/bin/env bash
# Generated by scalardb-starter-skills/scalardb-generate-config
#
# Creates the "scalardb-credentials" Secret consumed by custom-values.yaml
# (scalardbCluster.secretName). Run it before installing the Helm chart.
#
# The ScalarDB Cluster license key is NEVER stored in generated files.
# Provide it via the environment when running this script:
#
#   SCALAR_DB_CLUSTER_LICENSE_KEY='<your license key>' ./create-scalardb-secrets.sh
set -euo pipefail

K8S_NAMESPACE="${K8S_NAMESPACE:-{{K8S_NAMESPACE}}}"
SECRET_NAME="${SECRET_NAME:-scalardb-credentials}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -z "${SCALAR_DB_CLUSTER_LICENSE_KEY:-}" ]]; then
  echo "ERROR: SCALAR_DB_CLUSTER_LICENSE_KEY is not set." >&2
  echo "  SCALAR_DB_CLUSTER_LICENSE_KEY='<your license key>' $0" >&2
  exit 1
fi

kubectl get namespace "${K8S_NAMESPACE}" >/dev/null 2>&1 || kubectl create namespace "${K8S_NAMESPACE}"

kubectl create secret generic "${SECRET_NAME}" \
  --namespace "${K8S_NAMESPACE}" \
  --from-literal=CLUSTER_LICENSE_KEY="${SCALAR_DB_CLUSTER_LICENSE_KEY}" \
  --from-file=LICENSE_CHECK_CERT_PEM="${SCRIPT_DIR}/license_check_cert.pem" \
{{#each STORAGES}}
{{#if emit_username}}
  --from-literal=STORAGES_{{NAME_UPPER}}_USERNAME="${STORAGES_{{NAME_UPPER}}_USERNAME:-{{username_default}}}" \
{{/if}}
  --from-literal=STORAGES_{{NAME_UPPER}}_PASSWORD="${STORAGES_{{NAME_UPPER}}_PASSWORD:-{{password_default}}}" \
{{/each}}
  --dry-run=client -o yaml | kubectl apply -f -

echo "Secret ${SECRET_NAME} created/updated in namespace ${K8S_NAMESPACE}."
