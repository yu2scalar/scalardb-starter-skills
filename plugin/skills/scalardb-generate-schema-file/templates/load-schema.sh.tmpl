#!/usr/bin/env bash
# Generated by scalardb-starter-skills/scalardb-generate-schema-file
#
# Loads schema.json into the running ScalarDB Cluster by running the
# ScalarDB Cluster Schema Loader as a one-shot Kubernetes Job inside the
# cluster (no local Java or Docker required).
#
# Re-running is safe: existing tables are left as they are.
set -euo pipefail

K8S_NAMESPACE="${K8S_NAMESPACE:-{{K8S_NAMESPACE}}}"
RELEASE_NAME="${RELEASE_NAME:-{{RELEASE_NAME}}}"
LOADER_IMAGE="ghcr.io/scalar-labs/scalardb-cluster-schema-loader:{{SCALARDB_VERSION}}"
JOB_NAME="scalardb-schema-load"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Loader connects to the cluster from inside Kubernetes.
LOADER_PROPS="$(mktemp)"
trap 'rm -f "${LOADER_PROPS}"' EXIT
cat > "${LOADER_PROPS}" <<EOF
scalar.db.transaction_manager=cluster
scalar.db.contact_points=indirect:${RELEASE_NAME}-envoy.${K8S_NAMESPACE}.svc.cluster.local
scalar.db.contact_port=60053
{{#if AUTH_ENABLED}}
# Demo default superuser — change after first login (see README)
scalar.db.cluster.auth.enabled=true
scalar.db.username={{AUTH_USERNAME}}
scalar.db.password={{AUTH_PASSWORD}}
{{/if}}
EOF

echo "==> Creating ConfigMap with schema.json + loader properties"
kubectl create configmap "${JOB_NAME}" \
  --namespace "${K8S_NAMESPACE}" \
  --from-file=schema.json="${SCRIPT_DIR}/schema.json" \
  --from-file=loader.properties="${LOADER_PROPS}" \
  --dry-run=client -o yaml | kubectl apply -f -

echo "==> Deleting any previous loader Job"
kubectl delete job "${JOB_NAME}" --namespace "${K8S_NAMESPACE}" --ignore-not-found

echo "==> Starting Schema Loader Job (${LOADER_IMAGE})"
kubectl apply -f - <<EOF
apiVersion: batch/v1
kind: Job
metadata:
  name: ${JOB_NAME}
  namespace: ${K8S_NAMESPACE}
spec:
  backoffLimit: 0
  template:
    spec:
      restartPolicy: Never
      containers:
        - name: schema-loader
          image: ${LOADER_IMAGE}
          args:
            - "--config"
            - "/config/loader.properties"
            - "-f"
            - "/config/schema.json"
            - "--coordinator"
          volumeMounts:
            - name: config
              mountPath: /config
      volumes:
        - name: config
          configMap:
            name: ${JOB_NAME}
EOF

echo "==> Waiting for the Job to complete (timeout 300s)"
if kubectl wait --namespace "${K8S_NAMESPACE}" --for=condition=complete "job/${JOB_NAME}" --timeout=300s; then
  echo "==> Schema loaded successfully. Loader output:"
  kubectl logs "job/${JOB_NAME}" --namespace "${K8S_NAMESPACE}"
  echo "==> Cleaning up Job and ConfigMap"
  kubectl delete job "${JOB_NAME}" --namespace "${K8S_NAMESPACE}"
  kubectl delete configmap "${JOB_NAME}" --namespace "${K8S_NAMESPACE}"
else
  echo "ERROR: Schema Loader Job did not complete. Logs:" >&2
  kubectl logs "job/${JOB_NAME}" --namespace "${K8S_NAMESPACE}" >&2 || true
  echo "(Job and ConfigMap are kept for debugging: kubectl -n ${K8S_NAMESPACE} describe job/${JOB_NAME})" >&2
  exit 1
fi
